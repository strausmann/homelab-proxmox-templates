# Proxmox Verbindung
proxmox_url      = "https://PVE1:8006/api2/json"
proxmox_username = "terraform@pve!terraform-token"
proxmox_token    = "DEIN_TOKEN_HIER"
proxmox_node     = "PVE1"
proxmox_skip_tls = true  # Fuer Self-Signed Proxmox Certs

# VM Konfiguration
vm_id            = "9000"
vm_name          = "ubuntu-2404-packer"
template_name    = "tmpl-ubuntu-2404"
vm_cpu_cores     = 2
vm_memory        = 2048
vm_disk_size     = "20G"
vm_storage_pool  = "local-lvm"
vm_bridge        = "vnet60"

# ISO (Ubuntu 24.04.2 LTS)
iso_url          = "https://releases.ubuntu.com/24.04/ubuntu-24.04.2-live-server-amd64.iso"
iso_checksum     = "sha256:d6dab0c01a3a0bb4daaef8f33527b9bf91bf4ed9b97e516dc4ce8e8c3193c625"
iso_storage_pool = "local"

# SSH (temporaer fuer Packer Build, wird im Cleanup entfernt)
ssh_username     = "packer"
ssh_password     = "packer-build-only"
