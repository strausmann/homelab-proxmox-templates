#cloud-config
autoinstall:
  version: 1
  locale: de_DE.UTF-8
  keyboard:
    layout: de
    variant: ''
  timezone: Europe/Berlin
  identity:
    hostname: ubuntu-packer-build
    username: packer
    # Passwort: packer-build-only (SHA-512)
    password: "$6$NHXw3k9nzxXpgUlS$fL6YuqnX509A5hp4oaML9HvqrlQicOmQOQjBoyTwVMYbsI2hYx7clG7zlIeP0xbvRzKEQzuWmNTVNm4Qdn5CI/"
  ssh:
    install-server: true
    allow-pw: true
    authorized-keys:
      - "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIK6gqu8YPR+KppBxvK+rsQHKeWq5jY/zC5HJO3sPmx1K ansible-vm-homelab-nodes"
  packages:
    - qemu-guest-agent
    - curl
    - wget
    - vim
    - htop
    - jq
    - git
    - python3
    - python3-pip
    - cloud-init
    - apt-transport-https
    - ca-certificates
    - gnupg
    - lsb-release
    - unzip
  package_update: true
  package_upgrade: true
  network:
    ethernets:
      ens18:
        dhcp4: true
    version: 2
  storage:
    layout:
      name: lvm
  late-commands:
    # Packer User Sudo-Rechte (werden im Cleanup wieder entfernt)
    - "echo 'packer ALL=(ALL) NOPASSWD: ALL' >> /target/etc/sudoers.d/packer"
    - "chmod 440 /target/etc/sudoers.d/packer"
    # QEMU Guest Agent aktivieren
    - "curtin in-target -- systemctl enable qemu-guest-agent"
    # Timezone setzen
    - "curtin in-target -- timedatectl set-timezone Europe/Berlin"
