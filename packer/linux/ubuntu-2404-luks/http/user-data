#cloud-config
autoinstall:
  version: 1
  locale: de_DE.UTF-8
  keyboard:
    layout: de
    variant: ''
  timezone: Europe/Berlin
  identity:
    hostname: ubuntu-packer-build
    username: packer
    # Passwort: packer-build-only (SHA-512)
    password: "$6$NHXw3k9nzxXpgUlS$fL6YuqnX509A5hp4oaML9HvqrlQicOmQOQjBoyTwVMYbsI2hYx7clG7zlIeP0xbvRzKEQzuWmNTVNm4Qdn5CI/"
  ssh:
    install-server: true
    allow-pw: true
    authorized-keys:
      - "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIK6gqu8YPR+KppBxvK+rsQHKeWq5jY/zC5HJO3sPmx1K ansible-vm-homelab-nodes"
      - "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIARsgv7N7lCpWsn2jy8w8Se2sqKulcaAM8ACIda4B7gm strausmann"
  user-data:
    users:
      - name: packer
        sudo: ALL=(ALL) NOPASSWD:ALL
        shell: /bin/bash
        lock_passwd: true
        ssh_authorized_keys:
          - "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIK6gqu8YPR+KppBxvK+rsQHKeWq5jY/zC5HJO3sPmx1K ansible-vm-homelab-nodes"
          - "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIARsgv7N7lCpWsn2jy8w8Se2sqKulcaAM8ACIda4B7gm strausmann"
      - name: root
        ssh_authorized_keys:
          - "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIK6gqu8YPR+KppBxvK+rsQHKeWq5jY/zC5HJO3sPmx1K ansible-vm-homelab-nodes"
          - "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIARsgv7N7lCpWsn2jy8w8Se2sqKulcaAM8ACIda4B7gm strausmann"
  packages:
    - openssh-server
    - qemu-guest-agent
    - python3
    - cloud-init
    - curl
  package_update: true
  package_upgrade: true
  network:
    ethernets:
      enp6s18:
        dhcp4: true
        mtu: 1500
        nameservers:
          addresses:
            - 172.16.60.1
            - 1.1.1.1
    version: 2
  storage:
    config:
      - id: disk0
        type: disk
        ptable: gpt
        grub_device: true
      - id: esp
        type: partition
        device: disk0
        size: 512M
        flag: boot
        grub_device: true
      - id: esp-format
        type: format
        volume: esp
        fstype: fat32
      - id: boot-part
        type: partition
        device: disk0
        size: 1G
      - id: boot-format
        type: format
        volume: boot-part
        fstype: ext4
      - id: luks-part
        type: partition
        device: disk0
        size: -1
      # LUKS2 dm_crypt — kein LVM darunter (Direct-Layout)
      # Passphrase wird spaeter durch Keyfile ersetzt (late-commands)
      - id: luks-crypt
        type: dm_crypt
        volume: luks-part
        dm_name: crypt-root
        key: packer-build-only
      # Root-Filesystem direkt auf LUKS (kein LVM)
      - id: root-format
        type: format
        volume: luks-crypt
        fstype: ext4
      - id: mount-root
        type: mount
        device: root-format
        path: /
      - id: mount-boot
        type: mount
        device: boot-format
        path: /boot
      - id: mount-esp
        type: mount
        device: esp-format
        path: /boot/efi
  late-commands:
    # QEMU Guest Agent aktivieren (Packer braucht ihn fuer IP-Erkennung)
    - "curtin in-target -- systemctl enable qemu-guest-agent"
    # ===================================================================
    # KEYFILE-PROVISIONING auf /dev/sdb (Issue #214 Defekt #1)
    # /dev/sdb ist die Zweit-Disk (Packer scsi1, 16 MiB raw).
    # Die VM entsperrt LUKS damit beim Boot automatisch ohne Passphrase-Prompt.
    # Post-Deployment (Ansible clevis-tang-bind):
    #   1. Tang-Binding → Keyslot 3
    #   2. luksKillSlot 4 (Keyfile entfernen)
    #   3. Disk via Proxmox API detachen
    # ===================================================================
    # 1. Random-Keyfile schreiben (4096 Bytes am Anfang von /dev/sdb)
    - "dd if=/dev/urandom of=/dev/sdb bs=4096 count=1 conv=fsync"
    # 2. Keyfile als LUKS-Keyslot 4 hinzufuegen (mit Primaer-Passphrase entsperren)
    - "sh -c 'printf \"%s\" \"packer-build-only\" | cryptsetup luksAddKey --key-slot 4 --new-keyfile-size 4096 /dev/sda3 /dev/sdb'"
    # 3. crypttab auf Keyfile-Device umstellen (sdb entsperrt crypt-root beim Boot)
    #    Format: NAME  SOURCE-UUID  KEY-DEVICE  OPTIONS
    - "sh -c 'echo \"crypt-root UUID=$(blkid -s UUID -o value /dev/sda3) /dev/sdb luks,keyfile-size=4096,discard\" > /target/etc/crypttab'"
    # 4. Initramfs neu bauen — crypttab-Aenderung wird uebernommen
    - "curtin in-target -- update-initramfs -u -k all"
    # Packer User Sudo-Rechte (explizit mit tee statt >>)
    - "echo 'packer ALL=(ALL) NOPASSWD: ALL' | tee /target/etc/sudoers.d/packer"
    - "chmod 440 /target/etc/sudoers.d/packer"
    # Root SSH Keys
    - "mkdir -p /target/root/.ssh"
    - "echo 'ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIK6gqu8YPR+KppBxvK+rsQHKeWq5jY/zC5HJO3sPmx1K ansible-vm-homelab-nodes' >> /target/root/.ssh/authorized_keys"
    - "echo 'ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIARsgv7N7lCpWsn2jy8w8Se2sqKulcaAM8ACIda4B7gm strausmann' >> /target/root/.ssh/authorized_keys"
    - "chmod 700 /target/root/.ssh"
    - "chmod 600 /target/root/.ssh/authorized_keys"
    # Hinweis: Clevis/Tang-Binding erfolgt NICHT im Template-Build (Pfad B Split-Approach)
    # Grund: update-initramfs im live-installer-Kontext erzeugt kein funktionsfaehiges
    # Tang-faehiges initramfs (Recherche: docs/research/luks-clevis-tang-initramfs-ubuntu-2404.md)
    # Tang-Binding wird post-deployment per Ansible-Role clevis-tang-bind durchgefuehrt.
    # Hinweis: update-initramfs bereits weiter oben (Keyfile-crypttab) ausgefuehrt.
    # ===================================================================
    # GRUB-Cmdline bereinigen: autoinstall und ds=nocloud-net entfernen
    # Ubuntu Autoinstall traegt diese Parameter in /etc/default/grub ein.
    # Sie muessen vor Template-Erstellung entfernt werden damit geklonte VMs
    # beim naechsten Boot nicht erneut in den Autoinstall-Modus wechseln.
    # Defekte #5 (autoinstall in Cmdline) + #6 (ds=nocloud-net in Cmdline)
    # ===================================================================
    - "curtin in-target -- sed -i 's/GRUB_CMDLINE_LINUX_DEFAULT=.*/GRUB_CMDLINE_LINUX_DEFAULT=\"quiet splash\"/' /etc/default/grub"
    - "curtin in-target -- sed -i 's|GRUB_CMDLINE_LINUX=.*|GRUB_CMDLINE_LINUX=\"\"|' /etc/default/grub"
    - "curtin in-target -- update-grub"
    # ===================================================================
    # PACKER-USER CLEANUP via Cloud-Init runcmd (Defekt #3)
    # Problem: Der Packer-User kann sich nicht selbst loeschen waehrend eine
    # aktive SSH-Session als dieser User laeuft.
    # Loesung: Cloud-Init runcmd wird beim ersten Boot der geklonten VM
    # ausgefuehrt — dann existiert keine Packer-Session mehr.
    # Die Cleanup-Datei loescht sich selbst mit (kein Overlay-Effekt).
    # ===================================================================
    - "curtin in-target -- mkdir -p /etc/cloud/cloud.cfg.d"
    - |
      curtin in-target -- sh -c 'cat > /etc/cloud/cloud.cfg.d/99-packer-cleanup.cfg << '"'"'EOF'"'"'
      runcmd:
        - [ userdel, -rf, packer ]
        - [ rm, -f, /etc/sudoers.d/packer ]
        - [ rm, -f, /etc/cloud/cloud.cfg.d/99-packer-cleanup.cfg ]
      EOF'
